---
import BaseLayout from '../layouts/BaseLayout.astro';

const apiBaseUrl = import.meta.env.PUBLIC_LIBSEARCH_API_BASE_URL ?? 'http://localhost:3000';
---

<BaseLayout
  title="도서관 통합 검색"
  description="책 제목, 저자, ISBN으로 소장 도서관과 대출 가능 여부를 검색합니다."
>
  <section class="space-y-6" data-api-base-url={apiBaseUrl}>
    <div class="space-y-3">
      <p class="text-sm font-medium text-brand-600">Library Search</p>
      <h1 class="text-2xl font-bold text-gray-950">도서관 통합 검색</h1>
      <p class="text-sm leading-6 text-gray-600">
        책 이름이나 ISBN을 입력하면 소장 도서관과 대출 가능 상태를 한 번에 확인합니다.
      </p>
    </div>

    <form id="library-search-form" class="space-y-3">
      <div class="flex flex-col gap-2 sm:flex-row">
        <input
          id="library-search-query"
          name="q"
          type="search"
          autocomplete="off"
          placeholder="예: 불편한 편의점"
          class="min-h-12 flex-1 rounded-lg border border-gray-200 bg-white px-4 text-base text-gray-900 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100"
        />
        <button
          type="submit"
          class="min-h-12 rounded-lg bg-brand-600 px-5 text-sm font-semibold text-white transition hover:bg-brand-700 active:scale-[.99]"
        >
          검색
        </button>
      </div>

      <div class="grid gap-2 sm:grid-cols-[1fr_auto]">
        <select
          id="library-search-region"
          name="region"
          class="min-h-10 rounded-lg border border-gray-200 bg-white px-3 text-sm text-gray-700 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100"
        >
          <option value="">전체 지역</option>
          <option value="서울">서울</option>
          <option value="경기">경기</option>
          <option value="인천">인천</option>
          <option value="부산">부산</option>
          <option value="대구">대구</option>
          <option value="광주">광주</option>
          <option value="대전">대전</option>
          <option value="울산">울산</option>
          <option value="세종">세종</option>
          <option value="강원">강원</option>
          <option value="충북">충북</option>
          <option value="충남">충남</option>
          <option value="전북">전북</option>
          <option value="전남">전남</option>
          <option value="경북">경북</option>
          <option value="경남">경남</option>
          <option value="제주">제주</option>
        </select>

        <label class="flex min-h-10 items-center gap-2 rounded-lg border border-gray-200 px-3 text-sm text-gray-700">
          <input
            id="library-search-available"
            name="availableOnly"
            type="checkbox"
            class="h-4 w-4 rounded border-gray-300 text-brand-600 focus:ring-brand-500"
          />
          대출 가능만
        </label>
      </div>
    </form>

    <div id="library-search-status" class="hidden rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-600"></div>
    <div id="library-search-results" class="space-y-3"></div>
  </section>

  <script is:inline define:vars={{ apiBaseUrl }}>
    const form = document.getElementById('library-search-form');
    const queryInput = document.getElementById('library-search-query');
    const regionInput = document.getElementById('library-search-region');
    const availableInput = document.getElementById('library-search-available');
    const statusEl = document.getElementById('library-search-status');
    const resultsEl = document.getElementById('library-search-results');

    function setStatus(message, tone) {
      statusEl.textContent = message;
      statusEl.className = [
        'rounded-lg border px-4 py-3 text-sm',
        tone === 'error'
          ? 'border-red-200 bg-red-50 text-red-700'
          : 'border-gray-200 bg-gray-50 text-gray-600',
      ].join(' ');
      statusEl.classList.remove('hidden');
    }

    function clearStatus() {
      statusEl.classList.add('hidden');
      statusEl.textContent = '';
    }

    function escapeHtml(value) {
      return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function renderResults(items) {
      if (!items.length) {
        resultsEl.innerHTML =
          '<div class="rounded-lg border border-gray-200 bg-white p-5 text-sm text-gray-500">검색 결과가 없습니다.</div>';
        return;
      }

      resultsEl.innerHTML = items.map((item) => {
        const book = item.book;
        const libraries = item.libraries ?? [];
        const libraryRows = libraries.slice(0, 4).map(({ library, holding }) => {
          const available = holding.loanAvailable === true || holding.status === 'available';
          return `
            <li class="flex items-start justify-between gap-3 border-t border-gray-100 py-2 first:border-t-0">
              <div class="min-w-0">
                <p class="truncate text-sm font-medium text-gray-800">${escapeHtml(library.name)}</p>
                <p class="text-xs text-gray-500">${escapeHtml(library.region)}${library.district ? ' · ' + escapeHtml(library.district) : ''}</p>
              </div>
              <span class="shrink-0 rounded-full px-2 py-1 text-xs font-medium ${available ? 'bg-emerald-50 text-emerald-700' : 'bg-gray-100 text-gray-500'}">
                ${available ? '대출 가능' : '확인 필요'}
              </span>
            </li>
          `;
        }).join('');

        return `
          <article class="rounded-lg border border-gray-200 bg-white p-4">
            <div class="flex gap-4">
              ${book.thumbnail ? `<img src="${escapeHtml(book.thumbnail)}" alt="" class="h-28 w-20 shrink-0 rounded-md object-cover shadow-sm" loading="lazy" />` : '<div class="flex h-28 w-20 shrink-0 items-center justify-center rounded-md bg-gray-100 text-xs text-gray-400">No cover</div>'}
              <div class="min-w-0 flex-1">
                <h2 class="line-clamp-2 text-base font-semibold text-gray-950">${escapeHtml(book.title)}</h2>
                <p class="mt-1 text-sm text-gray-600">${escapeHtml((book.authors ?? []).join(', ') || '저자 정보 없음')}</p>
                <p class="mt-1 text-xs text-gray-500">${escapeHtml(book.publisher ?? '')}${book.publishedAt ? ' · ' + escapeHtml(book.publishedAt) : ''}</p>
                <div class="mt-3 flex flex-wrap gap-2 text-xs">
                  <span class="rounded-full bg-brand-50 px-2 py-1 font-medium text-brand-700">소장 ${item.totalHoldingCount}곳</span>
                  <span class="rounded-full bg-emerald-50 px-2 py-1 font-medium text-emerald-700">대출 가능 ${item.availableCount}곳</span>
                </div>
              </div>
            </div>
            <ul class="mt-3">${libraryRows}</ul>
          </article>
        `;
      }).join('');
    }

    async function runSearch() {
      const query = queryInput.value.trim();
      if (!query) {
        setStatus('검색어를 입력하세요.', 'error');
        queryInput.focus();
        return;
      }

      const params = new URLSearchParams({
        q: query,
        size: '10',
      });
      if (regionInput.value) params.set('region', regionInput.value);
      if (availableInput.checked) params.set('availableOnly', 'true');

      clearStatus();
      resultsEl.innerHTML = '';
      setStatus('검색 중입니다...', 'info');

      try {
        const response = await fetch(`${apiBaseUrl.replace(/\/$/, '')}/api/search?${params.toString()}`);
        const data = await response.json();

        if (!response.ok) {
          throw new Error(data?.error?.message ?? '검색 요청에 실패했습니다.');
        }

        clearStatus();
        renderResults(data.items ?? []);
        const nextUrl = new URL(window.location.href);
        nextUrl.searchParams.set('q', query);
        if (regionInput.value) nextUrl.searchParams.set('region', regionInput.value);
        else nextUrl.searchParams.delete('region');
        if (availableInput.checked) nextUrl.searchParams.set('availableOnly', 'true');
        else nextUrl.searchParams.delete('availableOnly');
        window.history.replaceState({}, '', nextUrl);
      } catch (error) {
        resultsEl.innerHTML = '';
        setStatus(error instanceof Error ? error.message : '검색 요청에 실패했습니다.', 'error');
      }
    }

    form.addEventListener('submit', (event) => {
      event.preventDefault();
      runSearch();
    });

    const initialParams = new URLSearchParams(window.location.search);
    const initialQuery = initialParams.get('q');
    if (initialQuery) {
      queryInput.value = initialQuery;
      regionInput.value = initialParams.get('region') ?? '';
      availableInput.checked = initialParams.get('availableOnly') === 'true';
      runSearch();
    }
  </script>

  <style is:inline>
    .line-clamp-2 {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  </style>
</BaseLayout>
