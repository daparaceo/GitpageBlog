---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CHAPTERS } from '../../data/security-chapters';
import fs from 'node:fs';
import path from 'node:path';

const questionsDir = path.resolve(process.cwd(), 'src/data/security-questions');
const examSlugs = fs.readdirSync(questionsDir)
  .filter(f => f.endsWith('.json'))
  .map(f => f.replace('.json', ''))
  .sort();

// CHAPTERS 데이터에서 과목별로 그룹화 (순서 유지)
const subjectOrder = ['system', 'network', 'application', 'general', 'law'];
const subjects = subjectOrder.map(slug => {
  const chs = CHAPTERS.filter(ch => ch.subject === slug);
  if (chs.length === 0) return null;
  const first = chs[0];
  return {
    slug,
    label: first.subjectLabel,
    chapters: chs.map(ch => ({ slug: ch.chapter, label: ch.chapterLabel })),
  };
}).filter(Boolean);
---

<BaseLayout title="보안기사 학습" description="정보보안기사 필기 준비 — 과목별 개념 정리와 기출문제 풀이">
  <div class="space-y-10">

    <!-- 헤더 -->
    <div class="border-b border-gray-200 pb-6">
      <h1 class="text-2xl font-bold text-gray-900 mb-2">정보보안기사 학습</h1>
      <p class="text-gray-500 text-sm">5과목 · 각 20문제 · 총 100점 · 60점 이상 합격</p>
    </div>

    <!-- 과목별 카드 -->
    <section>
      <h2 class="text-base font-semibold text-gray-700 mb-4">과목별 개념 학습</h2>
      <div class="space-y-3">
        {subjects.map((subject) => (
          <div class="border border-gray-200 rounded-lg overflow-hidden">
            <!-- 과목명 클릭 → 과목 인덱스 페이지 -->
            <a
              href={`/security/${subject.slug}/`}
              class="flex items-center justify-between px-4 py-3 hover:bg-sky-50 transition-colors group"
            >
              <span class="font-semibold text-gray-900 group-hover:text-sky-700">{subject.label}</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400 group-hover:text-sky-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
            <!-- 챕터 바로가기 -->
            <div class="flex flex-wrap gap-2 px-4 py-2 border-t border-gray-100 bg-gray-50">
              {subject.chapters.map((ch) => (
                <a
                  href={`/security/${subject.slug}/${ch.slug}/`}
                  class="text-xs px-2.5 py-1 rounded-full bg-white border border-gray-200 text-gray-500 hover:bg-sky-100 hover:text-sky-700 hover:border-sky-200 transition-colors"
                >
                  {ch.label}
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- 회차별 시험 -->
    <section>
      <h2 class="text-base font-semibold text-gray-700 mb-4">회차별 기출 시험</h2>
      {examSlugs.length === 0 ? (
        <p class="text-gray-400 text-sm">등록된 기출문제가 없습니다.</p>
      ) : (
        <div class="space-y-2">
          {examSlugs.map((slug) => {
            const [year, session] = slug.split('-');
            return (
              <a
                href={`/security/exam/${slug}/`}
                class="flex items-center justify-between p-4 border border-gray-200 rounded-lg hover:border-sky-300 hover:bg-sky-50 transition-colors group"
              >
                <div>
                  <span class="font-medium text-gray-900 group-hover:text-sky-700">
                    {year}년 {session}회 정보보안기사
                  </span>
                  <span class="text-xs text-gray-400 ml-2">100문제</span>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400 group-hover:text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            );
          })}
        </div>
      )}
    </section>

  </div>
</BaseLayout>
