---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { CHAPTERS } from '../../../../data/security-chapters';

export async function getStaticPaths() {
  const subjects = [
    { subject: 'system',      label: '시스템보안',          desc: '운영체제 보안, 접근통제, 암호학, 악성코드' },
    { subject: 'network',     label: '네트워크보안',        desc: '네트워크 기초, 방화벽·IDS·IPS, VPN' },
    { subject: 'application', label: '어플리케이션보안',    desc: '웹 보안, DB 보안, 소프트웨어 보안' },
    { subject: 'general',     label: '정보보안일반',        desc: '보안 일반 개념, 위험관리, 보안 모델' },
    { subject: 'law',         label: '정보보안관리및법규',  desc: '정보보호 관련 법규, ISMS, 개인정보보호' },
  ];

  return subjects.map(s => ({
    params: { subject: s.subject },
    props: s,
  }));
}

const { subject, label, desc } = Astro.props;
const chapters = CHAPTERS.filter(ch => ch.subject === subject);
---

<BaseLayout
  title={`${label} | 보안기사`}
  description={`정보보안기사 ${label} 핵심 개념 목록 — ${desc}`}
>
  <div class="space-y-8">

    <!-- Breadcrumb + 헤더 -->
    <div class="border-b border-gray-200 pb-4">
      <div class="text-xs text-gray-400 mb-2">
        <a href="/security/" class="hover:text-sky-600">보안기사</a>
        <span class="mx-1">/</span>
        <span>{label}</span>
      </div>
      <h1 class="text-xl font-bold text-gray-900">{label}</h1>
      <p class="text-sm text-gray-400 mt-0.5">{desc}</p>
    </div>

    <!-- 챕터 목록 -->
    <section>
      <div class="space-y-2">
        {chapters.map((ch, i) => (
          <a
            href={`/security/concept/${subject}/${ch.chapter}/`}
            class="flex items-center justify-between p-4 border border-gray-200 rounded-lg hover:border-sky-300 hover:bg-sky-50 transition-colors group"
          >
            <div class="flex items-center gap-3">
              <span class="text-xs text-gray-300 font-mono w-4">{String(i + 1).padStart(2, '0')}</span>
              <span class="font-medium text-gray-900 group-hover:text-sky-700">{ch.chapterLabel}</span>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400 group-hover:text-sky-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ))}
      </div>
    </section>

    <!-- 하단 네비게이션 -->
    <div class="pt-2 border-t border-gray-200">
      <a href="/security/" class="text-sm text-gray-500 hover:text-sky-600 transition-colors">
        ← 보안기사 학습 홈으로
      </a>
    </div>

  </div>
</BaseLayout>
