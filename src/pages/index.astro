---
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../content/config';
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

// 카테고리별 최신 글 3개씩
const postsByCategory = CATEGORIES.map(({ slug, label }) => ({
  slug,
  label,
  posts: sortedPosts.filter((p) => p.data.category === slug).slice(0, 3),
})).filter(({ posts }) => posts.length > 0);
---

<BaseLayout
  title="홈"
  description="생활정보, IT, 재테크 등 다양한 주제의 글을 공유하는 블로그입니다."
>
  <!-- 최신 글 전체 목록 (카테고리 없을 때도 표시) -->
  <section class="mb-12">
    <h2 class="text-lg font-bold text-gray-900 mb-4 pb-2 border-b border-gray-100">최신 글</h2>
    <ul class="divide-y divide-gray-100">
      {sortedPosts.slice(0, 5).map((post) => (
        <li class="py-4 group">
          <a href={`/blog/${post.slug}`} class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              {post.data.category && (
                <span class="text-xs text-brand-600 font-medium mr-2">
                  {CATEGORIES.find(c => c.slug === post.data.category)?.label}
                </span>
              )}
              <span class="text-base font-semibold text-gray-900 group-hover:text-brand-600 transition-colors">
                {post.data.title}
              </span>
              {post.data.description && (
                <p class="text-gray-500 text-sm mt-0.5 line-clamp-1">{post.data.description}</p>
              )}
            </div>
            <time datetime={post.data.publishedAt.toISOString()} class="text-xs text-gray-400 whitespace-nowrap mt-1">
              {post.data.publishedAt.toLocaleDateString('ko-KR', { month: 'short', day: 'numeric' })}
            </time>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- 카테고리별 섹션 -->
  {postsByCategory.map(({ slug, label, posts }) => (
    <section class="mb-10">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-lg font-bold text-gray-900">{label}</h2>
        <a href={`/category/${slug}`} class="text-xs text-brand-600 hover:underline">더 보기 →</a>
      </div>
      <ul class="divide-y divide-gray-100">
        {posts.map((post) => (
          <li class="py-3 group">
            <a href={`/blog/${post.slug}`} class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <span class="text-sm font-medium text-gray-800 group-hover:text-brand-600 transition-colors">
                  {post.data.title}
                </span>
              </div>
              <time datetime={post.data.publishedAt.toISOString()} class="text-xs text-gray-400 whitespace-nowrap">
                {post.data.publishedAt.toLocaleDateString('ko-KR', { month: 'short', day: 'numeric' })}
              </time>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</BaseLayout>
