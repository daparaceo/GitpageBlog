---
// src/pages/isbn-scan.astro
// 모바일 카메라로 책 바코드(EAN-13)를 스캔해 리뷰 포스트를 찾아주는 페이지

import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) =>
  !data.draft && data.category === 'english-reading'
);

// ISBN → 포스트 매핑 (빌드 타임에 생성)
interface PostMeta {
  slug: string;
  title: string;
  description: string;
  ogImage: string;
}
const isbnPostMap: Record<string, PostMeta> = {};

for (const post of posts) {
  const addEntry = (isbn: string) => {
    const clean = isbn.replace(/\D/g, '');
    if (clean.length >= 10 && !isbnPostMap[clean]) {
      isbnPostMap[clean] = {
        slug: post.slug.includes('/') ? post.slug.split('/').pop()! : post.slug,
        title: post.data.title,
        description: post.data.description ?? '',
        ogImage: post.data.ogImage ?? '',
      };
    }
  };

  // 1) frontmatter isbn 필드
  if (post.data.isbn) addEntry(String(post.data.isbn));

  // 2) 파일명 패턴: some-title_9781234567890
  const filename = post.slug.split('/').pop() ?? '';
  const m = filename.match(/_(97[89]\d{10})$/);
  if (m) addEntry(m[1]);
}

const BOOK_INFO_URL = 'https://api.daparapara.com/book-info';
---

<BaseLayout title="ISBN 스캔" description="책 바코드를 스캔해서 리뷰를 찾아보세요">
  <div class="max-w-sm mx-auto">

    <!-- 인앱 브라우저 경고 배너 (카카오톡·인스타·라인 등) -->
    <div id="inapp-banner" class="hidden mb-4 bg-amber-50 border border-amber-300 rounded-2xl p-4">
      <p class="text-sm font-semibold text-amber-800 mb-1">카메라 사용이 제한됩니다</p>
      <p class="text-xs text-amber-700 mb-3">카카오톡 등 앱 내 브라우저에서는 카메라 권한을 허용할 수 없습니다.<br>아래 방법으로 외부 브라우저에서 열어주세요.</p>
      <div class="bg-white rounded-xl p-3 text-xs text-gray-600 space-y-1.5">
        <p><b>카카오톡</b> — 우측 하단 <b>⋮</b> → <b>다른 브라우저로 열기</b></p>
        <p><b>인스타그램</b> — 우측 하단 <b>⋯</b> → <b>브라우저에서 열기</b></p>
        <p><b>라인</b> — 우측 상단 <b>⋮</b> → <b>브라우저로 열기</b></p>
      </div>
    </div>

    <!-- 페이지 헤더 -->
    <div class="mb-5">
      <a href="/search/" class="text-xs text-brand-600 hover:underline mb-3 inline-block">← 검색으로</a>
      <h1 class="text-xl font-bold text-gray-900">ISBN 바코드 스캔</h1>
      <p class="text-sm text-gray-500 mt-1">책 뒷면 바코드를 카메라로 스캔하면 AR 정보와 리뷰를 찾아드려요.</p>
    </div>

    <!-- 카메라 뷰파인더 -->
    <div
      id="scanner-wrap"
      class="relative bg-gray-900 rounded-2xl overflow-hidden mb-4"
      style="aspect-ratio: 4/3;"
    >
      <!-- html5-qrcode 가 여기에 video 삽입 -->
      <div id="qr-reader" class="absolute inset-0 w-full h-full"></div>

      <!-- 시작 전 오버레이 -->
      <div id="start-overlay" class="absolute inset-0 flex flex-col items-center justify-center gap-4">
        <!-- 바코드 아이콘 -->
        <svg class="w-12 h-12 text-gray-600" viewBox="0 0 48 48" fill="currentColor">
          <rect x="4"  y="10" width="3"  height="28"/>
          <rect x="9"  y="10" width="2"  height="28"/>
          <rect x="13" y="10" width="4"  height="28"/>
          <rect x="19" y="10" width="2"  height="28"/>
          <rect x="23" y="10" width="3"  height="28"/>
          <rect x="28" y="10" width="2"  height="28"/>
          <rect x="32" y="10" width="4"  height="28"/>
          <rect x="38" y="10" width="2"  height="28"/>
          <rect x="42" y="10" width="3"  height="28"/>
        </svg>
        <button
          id="start-btn"
          class="px-7 py-3 bg-sky-600 text-white text-sm font-semibold rounded-xl hover:bg-sky-700 active:scale-95 transition-all shadow-lg"
        >
          카메라 시작
        </button>
        <p class="text-xs text-gray-500 text-center px-6">카메라 권한 요청 시 허용을 눌러주세요</p>
      </div>

      <!-- 스캔 가이드 오버레이 (카메라 활성화 후 표시) -->
      <div id="scan-guide" class="hidden absolute inset-0 pointer-events-none">
        <!-- 어두운 마스크 + 스캔 영역 시각화 -->
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="relative w-4/5" style="height:80px">
            <!-- 스캔 박스 테두리 -->
            <div class="absolute inset-0 border border-sky-400/60 rounded"></div>
            <!-- 4 코너 마커 -->
            <div class="absolute -top-px -left-px w-6 h-6 border-t-2 border-l-2 border-sky-400 rounded-tl-sm"></div>
            <div class="absolute -top-px -right-px w-6 h-6 border-t-2 border-r-2 border-sky-400 rounded-tr-sm"></div>
            <div class="absolute -bottom-px -left-px w-6 h-6 border-b-2 border-l-2 border-sky-400 rounded-bl-sm"></div>
            <div class="absolute -bottom-px -right-px w-6 h-6 border-b-2 border-r-2 border-sky-400 rounded-br-sm"></div>
            <!-- 스캔 라인 -->
            <div id="scan-line" class="absolute left-1 right-1 h-px bg-sky-400"></div>
          </div>
        </div>
        <p class="absolute bottom-3 left-0 right-0 text-center text-white/70 text-xs">
          바코드를 박스 안에 맞춰주세요
        </p>
      </div>
    </div>

    <!-- 상태 메시지 -->
    <p id="status-msg" class="hidden text-center text-sm text-gray-500 mb-3"></p>

    <!-- 결과 카드 -->
    <div id="result-card" class="hidden mb-3"></div>

    <!-- 다시 스캔 버튼 -->
    <button
      id="rescan-btn"
      class="hidden w-full py-2.5 text-sm font-medium text-sky-600 border border-sky-200 rounded-xl hover:bg-sky-50 transition-colors mb-5"
    >
      다시 스캔하기
    </button>

    <!-- ISBN 직접 입력 -->
    <div class="border-t border-gray-100 pt-4 mt-2">
      <p class="text-xs text-gray-400 text-center mb-2">바코드 스캔이 안 되면 직접 입력하세요</p>
      <div class="flex gap-2">
        <input
          id="isbn-input"
          type="text"
          inputmode="numeric"
          pattern="[0-9]*"
          placeholder="ISBN 13자리 숫자"
          maxlength="14"
          class="flex-1 px-3 py-2.5 text-sm border border-gray-200 rounded-xl focus:outline-none focus:border-sky-400 transition-colors bg-white"
        />
        <button
          id="manual-search-btn"
          class="px-4 py-2.5 bg-gray-100 text-gray-700 text-sm font-medium rounded-xl hover:bg-gray-200 active:scale-95 transition-all"
        >
          검색
        </button>
      </div>
    </div>

    <!-- 제목/저자로 검색 -->
    <div class="border-t border-gray-100 pt-4 mt-4">
      <p class="text-xs text-gray-400 text-center mb-2">ISBN을 모른다면 제목이나 저자로 검색하세요</p>
      <div class="flex gap-2">
        <input
          id="title-input"
          type="text"
          placeholder="제목 또는 저자명 (영어)"
          class="flex-1 px-3 py-2.5 text-sm border border-gray-200 rounded-xl focus:outline-none focus:border-sky-400 transition-colors bg-white"
        />
        <button
          id="title-search-btn"
          class="px-4 py-2.5 bg-gray-100 text-gray-700 text-sm font-medium rounded-xl hover:bg-gray-200 active:scale-95 transition-all"
        >
          검색
        </button>
      </div>
      <!-- 검색 결과 목록 -->
      <div id="search-results" class="hidden mt-3 space-y-2"></div>
    </div>

  </div>

  <!-- html5-qrcode CDN (Android: BarcodeDetector 네이티브 API 자동 사용, iOS: ZXing 폴백) -->
  <script is:inline src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>

  <script is:inline define:vars={{ isbnPostMap, BOOK_INFO_URL }}>
    const ISBN_MAP = isbnPostMap;
    let html5QrCode = null;
    let isScanning   = false;

    // ── 인앱 브라우저 감지 ───────────────────────────────────
    (function detectInApp() {
      var ua = navigator.userAgent;
      var isInApp = /KAKAOTALK|Instagram|NAVER|Line\/|FB_IAB|FBAN|FBAV/i.test(ua);
      if (isInApp) {
        document.getElementById('inapp-banner').classList.remove('hidden');
      }
    })();

    // ── ISBN 정규화 ──────────────────────────────────────────
    function normalizeIsbn(raw) {
      var d = raw.replace(/\D/g, '');

      if (d.length === 13 && /^97[89]/.test(d)) return d;

      if (d.length === 14 && /^97[89]/.test(d)) {
        var b12 = d.slice(0, 12);
        var s = 0;
        for (var i = 0; i < 12; i++) s += parseInt(b12[i]) * (i % 2 === 0 ? 1 : 3);
        return b12 + ((10 - s % 10) % 10);
      }

      if (d.length === 15 && /^97[89]/.test(d)) return d.slice(0, 13);
      if (d.length === 18 && /^97[89]/.test(d)) return d.slice(0, 13);

      if (d.length === 10) {
        var base = '978' + d.slice(0, 9);
        var s2 = 0;
        for (var j = 0; j < 12; j++) s2 += parseInt(base[j]) * (j % 2 === 0 ? 1 : 3);
        return base + ((10 - s2 % 10) % 10);
      }

      return d;
    }

    // ── AR 레벨 배지 색상 ────────────────────────────────────
    function arBadgeClass(ar) {
      var n = parseFloat(ar);
      if (isNaN(n)) return 'bg-gray-100 text-gray-600';
      if (n < 1.0)  return 'bg-purple-100 text-purple-700';
      if (n < 3.5)  return 'bg-sky-100 text-sky-700';
      return 'bg-amber-100 text-amber-700';
    }

    // ── AR 정보 뱃지 HTML ────────────────────────────────────
    function arBadgesHtml(arData) {
      if (!arData) return '';
      var badges = [];
      if (arData.ar_level) {
        badges.push(
          '<span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold ' +
          arBadgeClass(arData.ar_level) + '">AR ' + arData.ar_level + '</span>'
        );
      }
      if (arData.lexile) {
        badges.push(
          '<span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium ' +
          'bg-gray-100 text-gray-600">' + arData.lexile + '</span>'
        );
      }
      if (arData.interest_level) {
        badges.push(
          '<span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium ' +
          'bg-gray-100 text-gray-600">' + arData.interest_level + '</span>'
        );
      }
      return badges.length
        ? '<div class="flex flex-wrap gap-1 mt-1.5">' + badges.join('') + '</div>'
        : '';
    }

    // ── 도서관 목록 HTML ─────────────────────────────────────
    function librariesHtml(libraries) {
      if (!libraries || !libraries.length) return '';
      var items = libraries.slice(0, 5).map(function(lib) {
        return '<li class="flex items-center justify-between gap-2 py-1">' +
          '<span class="text-xs text-gray-700 truncate">' + lib.name + '</span>' +
          (lib.distance
            ? '<span class="text-xs text-gray-400 flex-shrink-0">' + lib.distance + '</span>'
            : '') +
        '</li>';
      }).join('');
      return (
        '<div class="mt-2 border-t border-gray-100 pt-2">' +
          '<p class="text-xs font-medium text-gray-500 mb-1">소장 도서관</p>' +
          '<ul class="divide-y divide-gray-50">' + items + '</ul>' +
        '</div>'
      );
    }

    // ── 결과 카드: 리뷰 있음 ─────────────────────────────────
    function buildReviewCard(post, info) {
      var coverUrl     = (info && info.cover) ? info.cover : (post.ogImage || '');
      var arHtml       = arBadgesHtml(info);
      var titleDisplay = (info && info.title) ? info.title : post.title;
      var authorDisplay = (info && info.author)
        ? '<p class="text-xs text-gray-500 mt-0.5">' + info.author + '</p>'
        : '';
      var descHtml = (info && info.description)
        ? '<p class="text-xs text-gray-500 mt-1.5 line-clamp-2">' + info.description + '</p>'
        : '';
      var libHtml = librariesHtml(info && info.libraries);
      return (
        '<div class="bg-emerald-50 border border-emerald-200 rounded-2xl p-4">' +
          '<div class="flex gap-3">' +
            (coverUrl
              ? '<img src="' + coverUrl + '" alt="표지" ' +
                'class="w-14 h-20 object-cover rounded-lg shadow-sm flex-shrink-0" ' +
                'onerror="this.style.display=\'none\'">'
              : '') +
            '<div class="flex-1 min-w-0">' +
              '<p class="text-xs font-semibold text-emerald-600 mb-0.5">리뷰 있음</p>' +
              '<p class="font-semibold text-gray-900 text-sm leading-snug line-clamp-2">' +
                titleDisplay +
              '</p>' +
              authorDisplay +
              arHtml +
            '</div>' +
          '</div>' +
          descHtml +
          libHtml +
          '<div class="mt-3">' +
            '<a href="/blog/' + post.slug + '/" ' +
              'class="inline-block px-4 py-1.5 bg-emerald-600 text-white text-xs font-semibold rounded-lg ' +
              'hover:bg-emerald-700 active:scale-95 transition-all">' +
              '리뷰 보기' +
            '</a>' +
          '</div>' +
        '</div>'
      );
    }

    // ── 결과 카드: 리뷰 없음, 정보 있음 ─────────────────────
    function buildInfoCard(isbn, info) {
      var coverUrl  = info.cover || '';
      var arHtml    = arBadgesHtml(info);
      var seriesHtml = info.series
        ? '<p class="text-xs text-gray-400 mt-1">시리즈: ' + info.series + '</p>'
        : '';
      var descHtml = info.description
        ? '<p class="text-xs text-gray-500 mt-1.5 line-clamp-3">' + info.description + '</p>'
        : '';
      var libHtml = librariesHtml(info.libraries);
      return (
        '<div class="bg-gray-50 border border-gray-200 rounded-2xl p-4">' +
          '<div class="flex gap-3">' +
            (coverUrl
              ? '<img src="' + coverUrl + '" alt="표지" ' +
                'class="w-14 h-20 object-cover rounded-lg shadow-sm flex-shrink-0" ' +
                'onerror="this.style.display=\'none\'">'
              : '') +
            '<div class="flex-1 min-w-0">' +
              '<p class="text-xs font-semibold text-gray-500 mb-0.5">아직 리뷰가 없어요</p>' +
              (info.title
                ? '<p class="font-semibold text-gray-900 text-sm leading-snug line-clamp-2">' + info.title + '</p>'
                : '<p class="text-sm text-gray-500">ISBN ' + isbn + '</p>') +
              (info.author
                ? '<p class="text-xs text-gray-500 mt-0.5">' + info.author + '</p>'
                : '') +
              arHtml +
              seriesHtml +
            '</div>' +
          '</div>' +
          descHtml +
          libHtml +
        '</div>'
      );
    }

    // ── 결과 카드: 데이터 없음 ───────────────────────────────
    function buildNotFoundCard(isbn) {
      return (
        '<div class="bg-gray-50 border border-gray-200 rounded-2xl p-4">' +
          '<p class="text-xs font-semibold text-gray-500 mb-1">정보를 찾을 수 없어요</p>' +
          '<p class="text-sm text-gray-500">ISBN ' + isbn + '</p>' +
          '<p class="text-xs text-gray-400 mt-1">등록되지 않은 책이거나 바코드를 다시 확인해주세요.</p>' +
        '</div>'
      );
    }

    // ── ISBN → 4소스 조회 후 결과 표시 ──────────────────────
    async function showResult(rawIsbn) {
      var digits = rawIsbn.replace(/\D/g, '');
      if (!digits) return;

      var isbn = normalizeIsbn(rawIsbn);
      var post = ISBN_MAP[isbn] || ISBN_MAP[digits];

      var statusEl  = document.getElementById('status-msg');
      var resultEl  = document.getElementById('result-card');
      var rescanBtn = document.getElementById('rescan-btn');

      if (navigator.vibrate) navigator.vibrate(120);

      statusEl.textContent = 'ISBN: ' + isbn;
      statusEl.className   = 'text-center text-sm text-gray-400 mb-3';
      statusEl.classList.remove('hidden');

      // 로딩 상태
      resultEl.innerHTML =
        '<div class="bg-gray-50 border border-gray-100 rounded-2xl p-4 text-center text-sm text-gray-400">' +
        '도서 정보 조회 중...</div>';
      resultEl.classList.remove('hidden');
      rescanBtn.classList.remove('hidden');

      // 위치 정보 (도서관 거리 계산용) — 실패해도 계속
      var geoParams = '';
      try {
        var pos = await new Promise(function(resolve, reject) {
          navigator.geolocation.getCurrentPosition(resolve, reject, { timeout: 3000 });
        });
        geoParams = '&lat=' + pos.coords.latitude + '&lng=' + pos.coords.longitude;
      } catch (_) {}

      // book-info API 호출
      var info = null;
      try {
        var apiRes = await fetch(BOOK_INFO_URL + '?isbn=' + isbn + geoParams);
        if (apiRes.ok) info = await apiRes.json();
      } catch (_) {}

      // canonical_isbn 경유 재조회 (다른 에디션 ISBN 스캔 시)
      if (!post && info && info.canonical_isbn) {
        post = ISBN_MAP[info.canonical_isbn] || ISBN_MAP[info.canonical_isbn.replace(/\D/g, '')];
      }

      // 결과 카드 렌더
      if (post) {
        resultEl.innerHTML = buildReviewCard(post, info);
      } else if (info && (info.title || info.ar_level || info.lexile)) {
        resultEl.innerHTML = buildInfoCard(isbn, info);
      } else {
        resultEl.innerHTML = buildNotFoundCard(isbn);
      }
    }

    // ── 텍스트 검색 결과 항목 HTML ──────────────────────────
    function buildCandidateItem(item) {
      var arBadge = item.ar_level
        ? '<span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-semibold ' +
          arBadgeClass(item.ar_level) + '">AR ' + item.ar_level + '</span>'
        : '';
      return (
        '<button type="button" ' +
          'class="w-full text-left bg-white border border-gray-200 rounded-xl p-3 ' +
          'hover:border-sky-300 hover:bg-sky-50 active:scale-[0.98] transition-all" ' +
          'onclick="selectCandidate(' + JSON.stringify(item).replace(/"/g, '&quot;') + ')">' +
          '<div class="flex items-start justify-between gap-2">' +
            '<div class="min-w-0">' +
              '<p class="text-sm font-semibold text-gray-900 leading-snug line-clamp-2">' +
                (item.title || '(제목 없음)') +
              '</p>' +
              (item.author
                ? '<p class="text-xs text-gray-500 mt-0.5">' + item.author + '</p>'
                : '') +
            '</div>' +
            (arBadge ? '<div class="flex-shrink-0 mt-0.5">' + arBadge + '</div>' : '') +
          '</div>' +
        '</button>'
      );
    }

    // ── 텍스트 검색 실행 ─────────────────────────────────────
    async function searchByTitle(q) {
      var listEl = document.getElementById('search-results');
      listEl.innerHTML =
        '<p class="text-sm text-center text-gray-400 py-4">검색 중...</p>';
      listEl.classList.remove('hidden');

      try {
        var res = await fetch('https://api.daparapara.com/ar-lookup?q=' + encodeURIComponent(q));
        if (!res.ok) throw new Error('검색 실패 (' + res.status + ')');
        var results = await res.json();

        if (!Array.isArray(results) || results.length === 0) {
          listEl.innerHTML =
            '<p class="text-sm text-center text-gray-500 py-4">결과가 없어요. 영어 제목으로 검색해보세요.</p>';
          return;
        }

        listEl.innerHTML = results.map(buildCandidateItem).join('');
      } catch (e) {
        listEl.innerHTML =
          '<p class="text-sm text-center text-red-400 py-4">검색 오류: ' + e.message + '</p>';
      }
    }

    // ── 후보 선택 → AR 정보 카드 표시 ───────────────────────
    function selectCandidate(item) {
      var listEl   = document.getElementById('search-results');
      var resultEl = document.getElementById('result-card');
      var rescanEl = document.getElementById('rescan-btn');

      // 검색 목록 숨김
      listEl.classList.add('hidden');

      // AR 카드 표시
      var arHtml   = arBadgesHtml(item);
      var seriesHtml = item.series
        ? '<p class="text-xs text-gray-400 mt-1">시리즈: ' + item.series + '</p>'
        : '';
      resultEl.innerHTML =
        '<div class="bg-sky-50 border border-sky-200 rounded-2xl p-4">' +
          (item.title
            ? '<p class="font-semibold text-gray-900 text-sm leading-snug line-clamp-2">' +
              item.title + '</p>'
            : '') +
          (item.author
            ? '<p class="text-xs text-gray-500 mt-0.5">' + item.author + '</p>'
            : '') +
          arHtml +
          seriesHtml +
          '<p class="text-xs text-gray-400 mt-2">AR BookFinder 기준 정보입니다.</p>' +
        '</div>';
      resultEl.classList.remove('hidden');
      rescanEl.classList.remove('hidden');
      resultEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    // ── 스캐너 시작 ──────────────────────────────────────────
    async function startScanner() {
      if (isScanning) return;

      var startOverlay = document.getElementById('start-overlay');
      var scanGuide    = document.getElementById('scan-guide');
      var statusEl     = document.getElementById('status-msg');

      startOverlay.classList.add('hidden');
      statusEl.textContent = '카메라 초기화 중...';
      statusEl.className   = 'text-center text-sm text-gray-500 mb-3';
      statusEl.classList.remove('hidden');

      try {
        html5QrCode = new Html5Qrcode('qr-reader');

        await html5QrCode.start(
          { facingMode: 'environment' },
          {
            fps: 10,
            qrbox: { width: 260, height: 90 },
            formatsToSupport: [
              Html5QrcodeSupportedFormats.EAN_13,
              Html5QrcodeSupportedFormats.EAN_8,
            ],
            useBarCodeDetectorIfSupported: true,
          },
          function(decodedText) {
            if (!isScanning) return;
            isScanning = false;
            html5QrCode.stop().catch(function() {});
            scanGuide.classList.add('hidden');
            statusEl.classList.add('hidden');
            showResult(decodedText);
          },
          function() { /* 스캔 실패 무시 */ }
        );

        isScanning = true;
        statusEl.classList.add('hidden');
        scanGuide.classList.remove('hidden');
        startScanLineAnimation();

      } catch (err) {
        startOverlay.classList.remove('hidden');
        var errName = err && err.name ? err.name : '';
        var isInApp = /KAKAOTALK|Instagram|NAVER|Line\/|FB_IAB|FBAN|FBAV/i.test(navigator.userAgent);
        var msg;
        if (isInApp) {
          msg = '앱 내 브라우저에서는 카메라를 사용할 수 없습니다.\n우측 하단 ⋮ 메뉴에서 <b>다른 브라우저로 열기</b>를 선택해주세요.';
        } else if (errName === 'NotAllowedError' || errName === 'PermissionDeniedError') {
          msg = '카메라 권한이 거부되었습니다.\n주소창 옆 자물쇠(🔒) 아이콘을 눌러 권한을 허용한 뒤 다시 시도해주세요.';
        } else if (errName === 'NotFoundError' || errName === 'DevicesNotFoundError') {
          msg = '카메라를 찾을 수 없습니다. 다른 앱이 카메라를 사용 중이거나 카메라가 없는 기기입니다.';
        } else if (errName === 'NotReadableError' || errName === 'TrackStartError') {
          msg = '카메라가 다른 앱에서 사용 중입니다. 다른 앱을 닫고 다시 시도해주세요.';
        } else {
          msg = '카메라를 시작할 수 없습니다. 브라우저 권한 설정을 확인해주세요.';
        }
        var retryBtn = isInApp ? '' :
          '<br><button onclick="startScanner()" ' +
          'class="mt-3 inline-block px-4 py-2 bg-sky-600 text-white text-xs font-semibold rounded-lg hover:bg-sky-700">' +
          '다시 시도</button>';
        statusEl.innerHTML = msg.replace(/\n/g, '<br>') + retryBtn;
        statusEl.className = 'text-center text-sm text-red-500 mb-3';
        statusEl.classList.remove('hidden');
        console.error('[isbn-scan] 카메라 오류:', err);
      }
    }

    // ── 스캔 라인 애니메이션 ─────────────────────────────────
    function startScanLineAnimation() {
      var line = document.getElementById('scan-line');
      if (!line) return;
      var direction = 1;
      var pos = 4;
      (function animate() {
        if (!isScanning) return;
        pos += direction * 2;
        if (pos >= 74) direction = -1;
        if (pos <= 4)  direction =  1;
        line.style.top = pos + 'px';
        requestAnimationFrame(animate);
      })();
    }

    // ── 다시 스캔 ────────────────────────────────────────────
    function resetScanner() {
      document.getElementById('result-card').classList.add('hidden');
      document.getElementById('result-card').innerHTML = '';
      document.getElementById('rescan-btn').classList.add('hidden');
      document.getElementById('status-msg').classList.add('hidden');
      document.getElementById('scan-guide').classList.add('hidden');
      document.getElementById('start-overlay').classList.remove('hidden');
      document.getElementById('search-results').classList.add('hidden');
      if (html5QrCode) {
        html5QrCode.stop().catch(function() {});
        html5QrCode = null;
      }
      isScanning = false;
    }

    // ── 이벤트 바인딩 ────────────────────────────────────────
    document.getElementById('start-btn').addEventListener('click', startScanner);
    document.getElementById('rescan-btn').addEventListener('click', resetScanner);

    // ISBN 직접 입력
    document.getElementById('manual-search-btn').addEventListener('click', function() {
      var val = document.getElementById('isbn-input').value.trim();
      if (val.length >= 10) showResult(val);
    });
    document.getElementById('isbn-input').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        var val = e.target.value.trim();
        if (val.length >= 10) showResult(val);
      }
    });

    // 제목/저자 검색
    document.getElementById('title-search-btn').addEventListener('click', function() {
      var val = document.getElementById('title-input').value.trim();
      if (val.length >= 2) searchByTitle(val);
    });
    document.getElementById('title-input').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        var val = e.target.value.trim();
        if (val.length >= 2) searchByTitle(val);
      }
    });
  </script>

  <style is:inline>
    /* html5-qrcode 기본 UI 제거 — 커스텀 오버레이만 사용 */
    #qr-reader                 { border: none !important; padding: 0 !important; background: transparent !important; }
    #qr-reader video           { width: 100% !important; height: 100% !important; object-fit: cover !important; display: block !important; position: absolute !important; inset: 0 !important; }
    #qr-reader__dashboard      { display: none !important; }
    #qr-reader__status_span    { display: none !important; }
    #qr-reader__scan_region    { background: transparent !important; border: none !important; }
    #qr-reader__scan_region img { display: none !important; }

    /* 텍스트 2줄 줄임 */
    .line-clamp-2 {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  </style>
</BaseLayout>
