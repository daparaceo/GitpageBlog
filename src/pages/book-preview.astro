---
// src/pages/book-preview.astro
// ISBN으로 실시간 AI 참고 페이지 생성
// - URL: /book-preview?isbn=9781234567890
// - 로딩 화면(광고) → API 호출 → 결과 렌더
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="AI 참고 생성 중 | daparapara" description="영어 원서 AI 학습 가이드를 생성하고 있습니다.">
  <div id="loading-screen" class="min-h-screen flex flex-col items-center justify-center px-4 py-12">
    <!-- 책 표지 자리표시자 -->
    <div id="cover-placeholder" class="w-32 h-44 bg-gray-200 rounded-lg animate-pulse mb-6"></div>

    <!-- 제목 자리표시자 -->
    <div class="h-6 w-64 bg-gray-200 rounded animate-pulse mb-2"></div>
    <div class="h-4 w-40 bg-gray-200 rounded animate-pulse mb-8"></div>

    <!-- 광고 슬롯 (로딩 중) -->
    <div class="w-full max-w-xl my-4 flex items-center justify-center min-h-[90px] bg-gray-100 rounded text-gray-400 text-xs border border-dashed border-gray-300">
      광고
      <!-- TODO: AdSense 코드 삽입 -->
      <!-- <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-XXXXXX" data-ad-slot="XXXXXX" data-ad-format="auto" data-full-width-responsive="true"></ins> -->
    </div>

    <!-- 상태 메시지 -->
    <p id="status-msg" class="text-gray-500 text-sm mt-4">AI가 책을 분석하고 있습니다...</p>
    <div class="flex gap-1 mt-3">
      <span class="w-2 h-2 rounded-full bg-blue-400 animate-bounce" style="animation-delay: 0s"></span>
      <span class="w-2 h-2 rounded-full bg-blue-400 animate-bounce" style="animation-delay: 0.15s"></span>
      <span class="w-2 h-2 rounded-full bg-blue-400 animate-bounce" style="animation-delay: 0.3s"></span>
    </div>
  </div>

  <!-- 결과 컨테이너 (숨김 상태) -->
  <div id="result-container" class="hidden max-w-2xl mx-auto px-4 py-8">
    <!-- 정확도 배지 -->
    <div id="accuracy-badge" class="mb-4 flex items-center gap-2 text-sm text-gray-500"></div>

    <!-- 광고 슬롯 (상단) -->
    <div class="w-full my-4 flex items-center justify-center min-h-[90px] bg-gray-100 rounded text-gray-400 text-xs border border-dashed border-gray-300">
      광고
      <!-- TODO: AdSense 코드 삽입 -->
    </div>

    <!-- 책 콘텐츠 -->
    <div id="book-content" class="prose max-w-none"></div>

    <!-- 광고 슬롯 (중간 — 어휘와 인상깊은문장 사이에 JS로 삽입됨) -->
    <div id="mid-ad" class="w-full my-6 flex items-center justify-center min-h-[250px] bg-gray-100 rounded text-gray-400 text-xs border border-dashed border-gray-300">
      광고
      <!-- TODO: AdSense 코드 삽입 -->
    </div>

    <!-- 정식 포스트 안내 -->
    <div class="mt-8 p-4 bg-blue-50 rounded-lg text-sm text-blue-800">
      <b>더 정확한 정보를 원하시나요?</b><br>
      책 사진을 제공하시면 원문 기반 정식 포스트로 교체해 드립니다.
      <a href="/about" class="underline ml-1">자세히 보기</a>
    </div>
  </div>

  <!-- 오류 화면 -->
  <div id="error-screen" class="hidden min-h-screen flex flex-col items-center justify-center px-4 text-center">
    <p class="text-gray-600 mb-4">참고 페이지를 생성하지 못했습니다.</p>
    <a id="retry-btn" href="#" class="px-4 py-2 bg-blue-600 text-white rounded text-sm">다시 시도</a>
    <a href="/isbn-scan" class="mt-3 text-sm text-gray-500 underline">ISBN 스캔으로 돌아가기</a>
  </div>
</BaseLayout>

<style>
  /* 정식 포스트 CSS와 동일한 스타일 적용 */
  #book-content :global(.book-container) {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding: 1rem;
    background: #f9fafb;
    border-radius: 0.5rem;
  }
  #book-content :global(.book-cover) {
    width: 120px;
    height: auto;
    border-radius: 4px;
    object-fit: cover;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  }
  #book-content :global(.book-table) {
    font-size: 0.875rem;
    border-collapse: collapse;
  }
  #book-content :global(.book-table td) {
    padding: 0.25rem 0.5rem;
    vertical-align: top;
  }
  #book-content :global(.book-table .label) {
    font-weight: 600;
    color: #6b7280;
    white-space: nowrap;
    padding-right: 1rem;
  }
  #book-content :global(.tip-box) {
    background: #eff6ff;
    border-left: 4px solid #3b82f6;
    padding: 1rem 1.25rem;
    border-radius: 0 0.5rem 0.5rem 0;
    margin: 1.5rem 0;
  }
  #book-content :global(.tip-box h3) {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  #book-content :global(.section) {
    margin: 1.5rem 0;
  }
  #book-content :global(.section h3) {
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }
  #book-content :global(.vocab-item) {
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    margin-bottom: 0.75rem;
    cursor: pointer;
  }
  #book-content :global(.vocab-item:hover) { background: #f0f9ff; }
  #book-content :global(.vocab-text) {
    font-weight: 700;
    color: #1d4ed8;
    margin-bottom: 0.25rem;
  }
  #book-content :global(.vocab-meaning) {
    color: #374151;
    margin-bottom: 0.25rem;
  }
  #book-content :global(.vocab-example) {
    color: #6b7280;
    font-style: italic;
    font-size: 0.875rem;
    margin-bottom: 0.25rem;
  }
  #book-content :global(.vocab-note) {
    color: #9ca3af;
    font-size: 0.8rem;
  }
  #book-content :global(.quote-item) {
    border-left: 3px solid #f59e0b;
    padding: 0.75rem 1rem;
    margin-bottom: 1rem;
    cursor: pointer;
  }
  #book-content :global(.quote-text) {
    font-weight: 600;
    color: #92400e;
    margin-bottom: 0.25rem;
  }
  #book-content :global(.quote-translation) {
    color: #6b7280;
    font-size: 0.875rem;
    margin-bottom: 0.25rem;
  }
  #book-content :global(.quote-note) { color: #9ca3af; font-size: 0.8rem; }
  #book-content :global(details.review-toggle) {
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    margin-top: 1.5rem;
  }
  #book-content :global(details.review-toggle summary) {
    cursor: pointer;
    font-weight: 600;
    list-style: none;
  }
  #book-content :global(.review-en) { margin-top: 1rem; color: #374151; }
  #book-content :global(.review-ko) { margin-top: 0.75rem; color: #6b7280; }
</style>

<script>
(function () {
  var API_BASE = 'https://api.daparapara.com';

  // URL에서 ISBN 파싱
  var params = new URLSearchParams(window.location.search);
  var isbn = params.get('isbn') || '';

  var loadingEl   = document.getElementById('loading-screen');
  var resultEl    = document.getElementById('result-container');
  var errorEl     = document.getElementById('error-screen');
  var statusEl    = document.getElementById('status-msg');
  var contentEl   = document.getElementById('book-content');
  var badgeEl     = document.getElementById('accuracy-badge');
  var retryBtn    = document.getElementById('retry-btn');
  var midAdEl     = document.getElementById('mid-ad');

  var ACCURACY_LABELS = {
    'high':        '원문 기반',
    'medium-high': '블로그·교육 자료 참고',
    'medium':      '출판사 설명 기반',
    'low':         'AI 참고 정보',
  };
  var ACCURACY_COLORS = {
    'high':        'text-green-700 bg-green-50',
    'medium-high': 'text-blue-700 bg-blue-50',
    'medium':      'text-yellow-700 bg-yellow-50',
    'low':         'text-orange-700 bg-orange-50',
  };

  function showError() {
    loadingEl.classList.add('hidden');
    resultEl.classList.add('hidden');
    errorEl.classList.remove('hidden');
  }

  function showResult(data) {
    loadingEl.classList.add('hidden');
    errorEl.classList.add('hidden');

    // 정확도 배지
    var label = ACCURACY_LABELS[data.accuracy] || data.accuracy;
    var color = ACCURACY_COLORS[data.accuracy] || 'text-gray-600 bg-gray-50';
    badgeEl.innerHTML =
      '<span class="px-2 py-0.5 rounded text-xs font-medium ' + color + '">' + label + '</span>' +
      (data.accuracy !== 'high' ? '<span class="text-gray-400">· 원문 직접 확인 권장</span>' : '');

    // 콘텐츠 렌더
    contentEl.innerHTML = data.html;

    // 중간 광고를 핵심어휘 섹션 뒤에 삽입
    var sections = contentEl.querySelectorAll('.section');
    if (sections.length >= 1) {
      var vocabSection = sections[0];
      vocabSection.parentNode.insertBefore(midAdEl, vocabSection.nextSibling);
      midAdEl.classList.remove('hidden');
    }

    resultEl.classList.remove('hidden');

    // 페이지 제목 업데이트
    if (data.title) {
      document.title = data.title + ' | daparapara';
    }

    // TTS 이벤트 재등록 (BaseLayout의 TTS 핸들러 재초기화)
    if (typeof window.__ttsInit === 'function') {
      window.__ttsInit();
    }
  }

  function loadPreview() {
    if (!isbn) {
      showError();
      return;
    }

    retryBtn.href = '/book-preview?isbn=' + isbn;

    var messages = [
      'Open Library에서 원문을 검색 중...',
      'YouTube 낭독 영상을 찾는 중...',
      '교육 블로그 자료를 수집 중...',
      'AI가 어휘와 문장을 분석 중...',
    ];
    var msgIdx = 0;
    var msgTimer = setInterval(function () {
      msgIdx = (msgIdx + 1) % messages.length;
      statusEl.textContent = messages[msgIdx];
    }, 6000);

    fetch(API_BASE + '/book-preview?isbn=' + encodeURIComponent(isbn), {
      method: 'GET',
      headers: { 'Content-Type': 'application/json' },
    })
      .then(function (res) {
        clearInterval(msgTimer);
        if (!res.ok) throw new Error('HTTP ' + res.status);
        return res.json();
      })
      .then(function (data) {
        if (!data.html) throw new Error('빈 응답');
        showResult(data);
      })
      .catch(function () {
        clearInterval(msgTimer);
        showError();
      });
  }

  loadPreview();
})();
</script>
