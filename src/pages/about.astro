---
// About 페이지 — 애드센스 심사 필수 페이지
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="소개"
  description="daparapara 블로그를 소개합니다."
>
  <article class="max-w-none space-y-10">

    <!-- 인트로 -->
    <section>
      <h1 class="text-2xl font-bold text-gray-900 mb-3">블로그 소개</h1>
      <p class="text-gray-600 leading-relaxed">
        안녕하세요, <strong class="text-gray-900">daparapara</strong> 블로그입니다.<br />
        일상에서 바로 써먹을 수 있는 <strong class="text-gray-900">생활정보</strong>부터
        IT·기술, 재테크, 여행, 음식까지 — 누구나 쉽게 이해하고 활용할 수 있는 정보를 공유합니다.
      </p>
    </section>

    <!-- 다루는 주제 -->
    <section>
      <h2 class="text-lg font-semibold text-gray-900 mb-4">다루는 주제</h2>
      <div class="grid gap-3">
        {[
          { icon: '🏠', title: '생활정보', desc: '실생활에 바로 쓸 수 있는 정보와 팁' },
          { icon: '💻', title: 'IT·기술',  desc: '최신 기술 트렌드와 실용적인 디지털 활용법' },
          { icon: '💰', title: '재테크',   desc: '절약, 투자, 금융 상품 관련 정보' },
          { icon: '✈️', title: '여행',     desc: '국내외 여행 정보와 추천 코스' },
          { icon: '🍽️', title: '음식·맛집', desc: '레시피와 맛집 정보' },
          { icon: '⛺', title: '캠핑',     desc: '캠핑 장비, 장소, 꿀팁 정보' },
          { icon: '📚', title: '영어 원서', desc: '원서 리뷰와 영어 학습 콘텐츠' },
        ].map(({ icon, title, desc }) => (
          <div class="flex items-start gap-3 p-4 rounded-lg bg-gray-50 border border-gray-100">
            <span class="text-xl leading-none mt-0.5">{icon}</span>
            <div>
              <p class="font-semibold text-gray-800">{title}</p>
              <p class="text-sm text-gray-500 mt-0.5">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- 연락처 -->
    <section>
      <h2 class="text-lg font-semibold text-gray-900 mb-3">연락처</h2>
      <p class="text-gray-600 text-sm mb-3">글에 대한 문의, 제안, 오류 신고는 아래로 연락 주세요.</p>
      <a
        href="mailto:daparaceo@gmail.com"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-gray-200 bg-white text-sm text-gray-700 hover:border-brand-400 hover:text-brand-600 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        daparaceo@gmail.com
      </a>
    </section>

  </article>
</BaseLayout>
