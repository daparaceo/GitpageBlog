---
// src/pages/blog/[...slug].astro
// 블로그 글 상세 페이지
// getStaticPaths()로 빌드 시 모든 글의 경로를 미리 생성합니다 (정적 생성)

import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// 빌드 시 모든 블로그 글 경로 생성
export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => {
    return data.draft !== true;
  });

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

// 마크다운 본문 렌더링
const { Content } = await post.render();

// 날짜 포맷
const formattedDate = post.data.publishedAt.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// ===== 지도 임베드 URL 계산 =====
let mapSrc: string | null = null;
let mapLink: string | null = null;
if (post.data.lat != null && post.data.lng != null) {
  const lat = post.data.lat;
  const lng = post.data.lng;
  const delta = 0.008;
  const bbox = `${lng - delta},${lat - delta},${lng + delta},${lat + delta}`;
  mapSrc = `https://www.openstreetmap.org/export/embed.html?bbox=${bbox}&layer=mapnik&marker=${lat},${lng}`;
  mapLink = `https://www.openstreetmap.org/?mlat=${lat}&mlon=${lng}#map=16/${lat}/${lng}`;
}

// ===== 관련 포스트 자동 추천 =====
// 같은 카테고리 내에서 시리즈 > 저자 > AR레벨 > 태그 기준으로 점수 매겨 상위 3개 추천
const allPosts = await getCollection('blog', ({ data }) => data.draft !== true);
const currentData = post.data;

const relatedPosts = allPosts
  .filter((p) => p.slug !== post.slug && p.data.category === currentData.category)
  .map((p) => {
    let score = 0;
    // 같은 시리즈
    if (currentData.series && p.data.series && currentData.series === p.data.series) score += 4;
    // 같은 저자
    if (currentData.author && p.data.author && currentData.author === p.data.author) score += 3;
    // AR 레벨 유사도 (±0.5 이내 +2, ±1.5 이내 +1)
    if (currentData.ar_level !== undefined && p.data.ar_level !== undefined) {
      const diff = Math.abs(currentData.ar_level - p.data.ar_level);
      if (diff <= 0.5) score += 2;
      else if (diff <= 1.5) score += 1;
    }
    // 공통 태그
    if (currentData.tags && p.data.tags) {
      const sharedTags = currentData.tags.filter((t) => p.data.tags!.includes(t));
      score += sharedTags.length;
    }
    // 날짜 보너스 (동점 시 최신 포스트 우선 — YYYYMMDD / 100000000)
    const d = new Date(p.data.publishedAt);
    const dateBonus = (d.getFullYear() * 10000 + (d.getMonth() + 1) * 100 + d.getDate()) / 100000000;
    return { post: p, score: score + dateBonus };
  })
  .filter(({ score }) => score > 0.0001)
  .sort((a, b) => b.score - a.score)
  .slice(0, 3)
  .map(({ post }) => post);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.ogImage}
  isArticle={true}
  publishedDate={post.data.publishedAt.toISOString()}
>
  <article>
    <!-- ===== 글 헤더 ===== -->
    <header class="mb-8 pb-8 border-b border-gray-100">
      <!-- 태그 목록 -->
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-3">
          {post.data.tags.map((tag) => (
            <a
              href={`/tags/${tag}`}
              class="text-xs px-2 py-1 bg-brand-50 text-brand-700 rounded-full hover:bg-brand-100 transition-colors"
            >
              #{tag}
            </a>
          ))}
        </div>
      )}

      <!-- 제목 -->
      <h1 class="text-3xl font-bold text-gray-900 mb-3 leading-tight">
        {post.data.title}
      </h1>

      <!-- 설명 (있는 경우) -->
      {post.data.description && (
        <p class="text-gray-600 text-lg mb-4">{post.data.description}</p>
      )}

      <!-- 발행일 -->
      <time datetime={post.data.publishedAt.toISOString()} class="text-sm text-gray-400">
        {formattedDate}
      </time>
    </header>

    <!-- ===== 지도 임베드 (lat/lng 프론트매터가 있을 때만 표시) ===== -->
    {mapSrc && mapLink && (
      <div class="mb-8">
        <iframe
          src={mapSrc}
          width="100%"
          height="320"
          class="rounded-xl border border-gray-200 w-full"
          loading="lazy"
          title={post.data.mapLabel ?? post.data.title}
        ></iframe>
        <p class="text-xs text-gray-400 mt-1 text-right">
          <a href={mapLink} target="_blank" rel="noopener noreferrer" class="hover:underline">
            OpenStreetMap에서 크게 보기 ↗
          </a>
        </p>
      </div>
    )}

    <!-- ===================================================
      본문 콘텐츠 영역
      마크다운에서 변환된 HTML이 여기에 삽입됩니다.
      이미지는 Cloudinary URL로, 동영상은 YouTube iframe으로 삽입하세요.
    =================================================== -->
    <div
      data-pagefind-body
      class="
        prose prose-gray max-w-none
        prose-headings:font-bold prose-headings:text-gray-900
        prose-a:text-brand-600 prose-a:no-underline hover:prose-a:underline
        prose-img:rounded-xl prose-img:shadow-sm
        prose-code:text-brand-700 prose-code:bg-brand-50 prose-code:px-1 prose-code:rounded
        prose-pre:bg-gray-900 prose-pre:text-gray-100
      "
    >
      <Content />
    </div>

    <!-- ===== 글 하단 광고 영역 (애드센스/애드핏 단위 광고) ===== -->
    <!-- 애드센스 승인 후 아래 주석 해제하고 ID 교체
    <div class="mt-10 pt-6 border-t border-gray-100">
      구글 애드센스 단위 광고:
      <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-XXXXXXXXXXXXXXXX" data-ad-slot="XXXXXXXXXX" data-ad-format="auto" data-full-width-responsive="true"></ins>
      <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>

      카카오 애드핏 단위 광고:
      <ins class="kakao_ad_area" style="display:none;" data-ad-unit="DAN-XXXXXXXXXXXXXXXX" data-ad-width="320" data-ad-height="100"></ins>
    </div>
    -->

    <!-- ===== 관련 포스트 추천 ===== -->
    {relatedPosts.length > 0 && (
      <section class="mt-12 pt-8 border-t border-gray-100">
        <h3 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
          <span>📚</span> 이런 글도 추천해요
        </h3>
        <div class="flex flex-col gap-3">
          {relatedPosts.map((related) => (
            <a
              href={`/blog/${related.slug}`}
              class="block bg-gray-50 hover:bg-blue-50 border border-gray-200 hover:border-blue-300 rounded-lg px-4 py-3 transition-all group"
            >
              <span class="text-blue-600 group-hover:underline text-sm font-medium">
                {related.data.title}
              </span>
              {related.data.description && (
                <p class="text-gray-500 text-xs mt-1 line-clamp-1">{related.data.description}</p>
              )}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- ===== 글 하단 내비게이션 ===== -->
    <nav class="mt-8 pt-6 border-t border-gray-100">
      <a
        href="/"
        class="text-sm text-brand-600 hover:underline"
      >
        ← 목록으로 돌아가기
      </a>
    </nav>
  </article>
</BaseLayout>
